# ============================================
# Calendar App Desktop - Backend Environment
# Μετονόμασε αυτό το αρχείο σε: .env
# ΠΟΤΕ μην ανεβάσεις το .env στο GitHub!
# ============================================

DJANGO_SECRET_KEY=your-super-secret-key-minimum-50-chars
DEBUG=True

# PostgreSQL (local)
DB_NAME=calendar_app_desktop
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Supabase / Render - χρησιμοποίησε αυτό αντί των παραπάνω:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google OAuth2
# Από: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/

# Redis / Upstash
# Local: redis://localhost:6379/0
# Upstash: rediss://default:PASSWORD@ENDPOINT.upstash.io:PORT
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Προσθέσε το Vercel URL μετά το πρώτο deploy:
# CORS_ALLOWED_ORIGINS=https://calendar-app-desktop.vercel.app
